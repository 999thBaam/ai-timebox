# AI Timebox Backend Configuration
# Copy this file to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aitimebox

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (frontend URL)
CORS_ORIGINS=["http://localhost:3000"]

# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini

# Debug mode
DEBUG=true
